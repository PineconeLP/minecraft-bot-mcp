{
  "name": "minecraft-bot-mcp",
  "version": "1.0.1",
  "mcpName": "io.github.pineconelp/minecraft-bot-mcp",
  "description": "An MCP server to create and control Minecraft bots via Mineflayer.",
  "main": "dist/index.js",
  "bin": {
    "minecraft-bot-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "npm run clean && tsc",
    "inspect": "npm run build && npx @modelcontextprotocol/inspector node dist/index.js",
    "start": "npm run build && node dist/index.js",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PineconeLP/minecraft-bot-mcp"
  },
  "author": "PineconeLP",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "minecraft-data": "^3.111.0",
    "mineflayer": "^4.37.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
